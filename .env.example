# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token

# Encryption key for wallet seeds (32-byte hex = 64 chars)
ENCRYPTION_KEY=your_64_char_hex_key

# Keeta Network (test or main)
KEETA_NETWORK=test

# Web server port
PORT=3000

# Base URL for payment links
BASE_URL=https://keetatip.xyz
